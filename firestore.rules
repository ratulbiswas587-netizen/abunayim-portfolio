rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    // Only allow specific users, or check auth for now since it's a personal app.
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /projects/{projectId} {
      allow read: if true;
      allow list: if true;
      
      allow create: if isSignedIn() 
        && isValidId(projectId)
        && request.resource.data.keys().hasAll(['title', 'categoryId', 'imageUrl', 'createdAt', 'ownerId'])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
        && request.resource.data.categoryId is number
        && (request.resource.data.keys().hasAll(['subCategoryId']) ? request.resource.data.subCategoryId is number : true)
        && (request.resource.data.keys().hasAll(['clientName']) ? (request.resource.data.clientName == null || (request.resource.data.clientName is string && request.resource.data.clientName.size() <= 200)) : true)
        && request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() <= 1048487
        && request.resource.data.createdAt == request.time;
        
      allow update: if isSignedIn() 
        && isValidId(projectId)
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'clientName', 'categoryId', 'subCategoryId', 'imageUrl', 'videoUrl', 'updatedAt'])
        && (request.resource.data.get('title', resource.data.title) is string)
        && (request.resource.data.get('clientName', resource.data.get('clientName', null)) == null || request.resource.data.get('clientName', null) is string)
        && (request.resource.data.get('categoryId', resource.data.categoryId) is number)
        && (request.resource.data.get('subCategoryId', resource.data.get('subCategoryId', 0)) is number)
        && (request.resource.data.get('imageUrl', resource.data.imageUrl) is string);

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
